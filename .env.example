# Copy to .env and fill in values

# Database (local dev)
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexus_dev

# JWT secret (change in production)
JWT_SECRET=nexus-dev-secret-change-me

# For production migrations (non-pooling Supabase URL)
# POSTGRES_URL_NON_POOLING=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase JS client (Project Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
